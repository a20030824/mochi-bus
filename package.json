{
  "name": "mochi-bus",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/a20030824/mochi-bus.git"
  },
  "homepage": "https://bus.moc96336.com/",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:map": "vite build",
    "dev": "npm run build:map && wrangler dev",
    "deploy": "npm run build:map && wrangler deploy --minify",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "check": "npm run cf-typegen:check && npm run test && npm run typecheck && npm run build:map && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings --env-file .dev.vars.example",
    "cf-typegen:check": "wrangler types --env-interface CloudflareBindings --env-file .dev.vars.example --check",
    "snapshot:chiayi": "node scripts/sync-chiayi-snapshot.mjs Chiayi",
    "snapshot:city": "node scripts/sync-chiayi-snapshot.mjs",
    "snapshot:rollback": "node scripts/transit-snapshot/rollback.mjs"
  },
  "dependencies": {
    "hono": "^4.12.27",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.21",
    "aws4fetch": "^1.0.20",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.4.0"
  }
}
